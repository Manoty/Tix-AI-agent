# App
APP_ENV=development
APP_SECRET_KEY=changeme_use_a_long_random_string_here
APP_DEBUG=true

# PostgreSQL
POSTGRES_USER=tix_user
POSTGRES_PASSWORD=tix_password
POSTGRES_DB=tix_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET_KEY=changeme_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7